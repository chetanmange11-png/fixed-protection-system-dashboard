{
  "entities": {
    "Plant": {
      "title": "Plant",
      "description": "Facility or plant unit being tracked.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subSystemId": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "unitType": { "type": "string" },
        "financialYear": { "type": "string" }
      },
      "required": ["id", "code", "name"]
    },
    "SystemCategory": {
      "title": "System Category",
      "description": "High-level system category (e.g., Fixed System).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "financialYear": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "SubSystem": {
      "title": "Sub System",
      "description": "Specific sub-folder or sub-system within a category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "financialYear": { "type": "string" }
      },
      "required": ["id", "categoryId", "name"]
    },
    "TestRecord": {
      "title": "Test Record",
      "description": "Detailed record of a safety test.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plantId": { "type": "string" },
        "plantName": { "type": "string" },
        "subSystemId": { "type": "string" },
        "subSystemName": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "cycle": { "type": "string" },
        "scheduleMonth": { "type": "string" },
        "testDate": { "type": "string" },
        "dateOfTesting": { "type": "string" },
        "status": { "type": "string" },
        "healthCondition": { "type": "string" },
        "financialYear": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "plantId", "subSystemId", "categoryId", "financialYear"]
    },
    "User": {
      "title": "User",
      "description": "Application user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "role"]
    },
    "RecycledItem": {
      "title": "Recycled Item",
      "description": "Item moved to recycle bin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "data": { "type": "object" },
        "deletedAt": { "type": "string" }
      },
      "required": ["id", "type", "data", "deletedAt"]
    },
    "IsolationReport": {
      "title": "Isolation Report",
      "description": "Report for fire water isolation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plantId": { "type": "string" },
        "financialYear": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "plantId", "financialYear", "status"]
    },
    "EquipmentIssue": {
      "title": "Equipment Issue",
      "description": "Reported equipment defect.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plantId": { "type": "string" },
        "financialYear": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "plantId", "financialYear", "status"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Immutable log for tracking sensitive state changes.",
      "type": "object",
      "properties": {
        "recordId": { "type": "string" },
        "actionType": { "type": "string" },
        "userId": { "type": "string" },
        "system": { "type": "string" },
        "changes": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["recordId", "actionType", "userId", "timestamp"]
    }
  },
  "firestore": {
    "plants": { "schema": "Plant", "description": "Collection of plants/facilities." },
    "categories": { "schema": "SystemCategory", "description": "System category folders." },
    "subsystems": { "schema": "SubSystem", "description": "Sub-system folders." },
    "testRecords": { "schema": "TestRecord", "description": "Master testing records." },
    "users": { "schema": "User", "description": "Application users." },
    "recycleBin": { "schema": "RecycledItem", "description": "Deleted items cache." },
    "isolationReports": { "schema": "IsolationReport", "description": "Isolation logs." },
    "equipmentIssues": { "schema": "EquipmentIssue", "description": "Defect tracking logs." },
    "AuditLogs": { "schema": "AuditLog", "description": "Compliance audit trail." },
    "settings": { "schema": "object", "description": "Global application settings." },
    "activeYear": { "schema": "object", "description": "Current active financial year." }
  }
}
