rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidPlant(data) {
      return data.keys().hasAll(['id', 'code', 'name']) &&
             data.id is string && data.id.size() <= 64 &&
             data.code is string && data.code.size() <= 32 &&
             data.name is string && data.name.size() <= 256;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 256;
    }

    function isValidSubSystem(data) {
      return data.keys().hasAll(['id', 'categoryId', 'name']) &&
             data.id is string && data.id.size() <= 64 &&
             data.categoryId is string && data.categoryId.size() <= 64 &&
             data.name is string && data.name.size() <= 256;
    }

    function isValidTestRecord(data) {
      return data.keys().hasAll(['id', 'plantId', 'subSystemId', 'categoryId', 'financialYear', 'status']) &&
             data.id is string && data.id.size() <= 64 &&
             data.plantId is string && data.plantId.size() <= 64 &&
             data.status is string && data.status in ['Completed', 'Pending', 'Overdue', 'Under Maintenance', 'Due Soon'];
    }

    // --- Collection Rules ---

    match /plants/{plantId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(plantId) && isValidPlant(incoming());
      allow update: if isSignedIn() && isValidPlant(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'code', 'subSystemId', 'unitType', 'financialYear'])
      );
      allow delete: if isSignedIn();
    }

    match /categories/{catId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(catId) && isValidCategory(incoming());
      allow update: if isSignedIn() && isValidCategory(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'icon', 'financialYear'])
      );
      allow delete: if isSignedIn();
    }

    match /subsystems/{subId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(subId) && isValidSubSystem(incoming());
      allow update: if isSignedIn() && isValidSubSystem(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'categoryId', 'financialYear'])
      );
      allow delete: if isSignedIn();
    }

    match /testRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recordId) && isValidTestRecord(incoming());
      allow update: if isSignedIn() && isValidTestRecord(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'status', 'healthCondition', 'testDate', 'dateOfTesting', 'deficiency', 
          'remarks', 'testerName', 'checklist', 'updatedAt', 'attachmentUrl',
          'actionTaken', 'financialYear', 'cycleId', 'cycle', 'scheduleMonth'
        ])
      );
      allow delete: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(userId);
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /activeYear/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /recycleBin/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(itemId);
      allow delete: if isSignedIn();
    }

    match /isolationReports/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /equipmentIssues/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /checklistMaster/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /testCycles/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /plantEquipment/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /historicalReports/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Safety check path
    match /test/connection {
      allow get: if isSignedIn();
    }
  }
}
